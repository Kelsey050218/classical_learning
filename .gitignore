# ============================================
# 经典常谈伴学平台 - Git Ignore
# 适用于 Public GitHub 仓库
# ============================================

# --------------------------------------------
# OS 系统文件
# --------------------------------------------
.DS_Store
Thumbs.db
desktop.ini
*.lnk

# --------------------------------------------
# IDE / 编辑器
# --------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~
*.sublime-project
*.sublime-workspace

# --------------------------------------------
# Python (Backend)
# --------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# 虚拟环境
venv/
.venv/
env/
ENV/

# 构建/分发
*.egg-info/
.eggs/
dist/
build/
*.egg
MANIFEST

# 测试/覆盖率
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/
.mypy_cache/
.ruff_cache/

# Pip
pip-log.txt
pip-delete-this-directory.txt

# --------------------------------------------
# Node.js (Frontend)
# --------------------------------------------
node_modules/
.pnpm-debug.log*
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-store/

# Vite
.vite/

# 前端构建产物
/dist
/build

# --------------------------------------------
# 环境变量与密钥 (绝不提交)
# --------------------------------------------
.env
.env.local
.env.*.local
.env.development
.env.production
.env.test

# 保留示例文件
!.env.example

# 密钥/证书
*.pem
*.key
*.p12
*.pfx
*.crt
*.csr
id_rsa
id_ed25519
id_ecdsa
.ssh/

# --------------------------------------------
# 日志文件
# --------------------------------------------
*.log
logs/
backend.log
vite.log

# --------------------------------------------
# 数据库文件
# --------------------------------------------
*.db
*.sqlite
*.sqlite3
*.db-journal

# Docker 数据卷
mysql_data/

# --------------------------------------------
# 上传/临时文件
# --------------------------------------------
uploads/
temp/
tmp/

# --------------------------------------------
# 部署配置与文档 (服务器相关，不适合公开)
# --------------------------------------------
.superpowers/
project/docs/
project/classics-backend.service
project/deploy.sh
project/docker-compose.yml
project/nginx.conf

# --------------------------------------------
# 文档/数据 (如需要保留，请注释掉)
# --------------------------------------------
docs/
